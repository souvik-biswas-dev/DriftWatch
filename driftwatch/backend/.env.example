# DriftWatch backend — copy to .env and fill in.
# Never commit the populated .env to source control.
#
# New to this? See SETUP.md in the repo root — it lists every value below, where
# to get it (all free tier), and how to host the backend for free.
#
# Minimum to boot: DATABASE_URL, REDIS_URL, JWT_SECRET. Everything else is
# optional. AI (Gemini) is OFF by default — drift detection works without it.
#
# Note: projects no longer store a Docker host. Each user runs the DriftWatch
# agent (cmd/agent) on their own server; it pushes live Docker state to the
# backend using a per-project agent key. Nothing to configure here for that.

# ----- Server -----
# Port the HTTP server listens on. Defaults to 8080 if unset.
PORT=8080

# Comma-separated list of origins allowed by CORS (use exact origins, not "*"
# when Authorization is in play). The dashboard's dev server defaults to 5173.
ALLOWED_ORIGIN=http://localhost:5173

# ----- Postgres (Neon) -----
# Required. Standard postgres:// URL. Neon requires sslmode=require.
# Prefer the "Pooled connection" string from the Neon console for app traffic.
DATABASE_URL=postgres://user:password@ep-xxx.region.aws.neon.tech/driftwatch?sslmode=require

# ----- Redis (Upstash) -----
# Required. rediss:// for TLS connections from Upstash, redis:// for local.
REDIS_URL=rediss://default:PASSWORD@xxx.upstash.io:6379

# ----- Gemini -----
# API key for Google AI Studio's Gemini API (used to summarize drifts and
# suggest fix commands). OPTIONAL — leave blank to disable AI; drift detection
# still works. Get one free at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Which Gemini model to use. Defaults to gemini-2.5-flash (free tier). Other
# free options: gemini-2.5-flash-lite, gemini-2.0-flash, gemini-flash-latest.
GEMINI_MODEL=gemini-2.5-flash

# ----- GitHub -----
# Personal access token used by the github client to read declared compose
# files. Required for private repos; public repos can leave it blank.
# Scopes needed: repo (or contents:read on fine-grained tokens).
GITHUB_TOKEN=

# ----- Discord -----
# Webhook URL the alerts package POSTs drift alerts to. Empty to disable.
DISCORD_WEBHOOK_URL=

# ----- Server-side secrets -----
# Used to sign JWTs issued by /api/auth/login. MUST be >= 32 random bytes
# in production. Generate with: openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-string

# Shared secret the Cloudflare worker sends in X-DriftWatch-Secret when
# forwarding GitHub webhooks. Must match DRIFTWATCH_SECRET set on the worker.
WEBHOOK_SECRET=change-me-to-a-long-random-string

# Encryption key for users' GitHub tokens (OAuth + per-project) stored in the DB.
# REQUIRED for a real multi-user deploy (otherwise tokens are stored plaintext).
# Generate with: openssl rand -base64 48
ENCRYPTION_KEY=change-me-to-a-long-random-string

# ----- GitHub OAuth (sign-in) -----
# Create a GitHub OAuth App: https://github.com/settings/developers → New OAuth App
#   Homepage URL:               your dashboard URL (e.g. https://driftwatch.pages.dev)
#   Authorization callback URL: <BACKEND_URL>/api/auth/github/callback
# Then copy the Client ID and generate a Client Secret.
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# Where the OAuth callback sends users back to (the dashboard SPA). Locally this
# is the Vite dev server; in prod it's your Cloudflare Pages URL.
DASHBOARD_URL=http://localhost:5173

# This backend's external base URL, used to build the OAuth redirect_uri. Set in
# production (e.g. https://driftwatch-xxxx.onrender.com). Blank = inferred from
# the request host, which is fine for local dev.
BACKEND_URL=
